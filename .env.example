# ─────────────────────────────────────────────
# Loop — Meeting Brief & De-brief Agent
# ─────────────────────────────────────────────

# Slack Integration
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_SIGNING_SECRET=your-slack-signing-secret

# AI Provider (Groq — used inside RocketRide pipeline via llm_openai_api node)
GROQ_API_KEY=gsk_your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# Wrapper API (Butterbase + XTrace backend)
WRAPPER_BASE_URL=https://submammary-correlatively-irma.ngrok-free.dev

# RocketRide Cloud (pipeline orchestration engine)
# Sign up at https://rocketride.ai to get your API key
ROCKETRIDE_URI=wss://api.rocketride.ai
ROCKETRIDE_APIKEY=your-rocketride-api-key

# For local development with self-hosted RocketRide engine:
# ROCKETRIDE_URI=ws://localhost:5565
# ROCKETRIDE_APIKEY=
